{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agent Hub",
  "version": "0.1.0",
  "identifier": "com.xiaoleiy.agent-hub",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Agent Hub",
        "label": "main",
        "width": 900,
        "height": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "category": "DeveloperTool",
    "shortDescription": "Manage AI coding agents on your machine",
    "longDescription": "Agent Hub monitors and manages Claude Code, Cursor, and Codex sessions on your macOS machine. View system status, track agent usage, and keep your machine awake while agents are running."
  }
}
